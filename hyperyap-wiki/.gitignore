# Local Obsidian state
.obsidian/workspace*.json
.obsidian/cache/
.obsidian/plugins/
.obsidian/themes/
.obsidian/.trash/
.trash/

# Private raw material
.raw/private/
.raw/transcripts/*
!.raw/transcripts/.gitkeep
.raw/screenshots/*
!.raw/screenshots/.gitkeep
.raw/data/private/
.raw/assets/private/

# Private attachments
_attachments/private/
_attachments/raw/
_attachments/screenshots/
_attachments/transcripts/

# Environment and secret-like files
.env
.env.*
!.env.example
*.env
*.local
*.secret
*.secrets
*secret*
*token*
*password*
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
*.kdbx
